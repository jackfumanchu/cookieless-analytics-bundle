{% extends layout %}

{% block content %}
  {# ─── Controls Left ─── #}
  <div class="controls-left events-controls">
    <span class="page-headline">Events Dispatch</span>
    <span class="page-count">{{ distinctTypes }} distinct event{{ distinctTypes != 1 ? 's' : '' }}</span>
  </div>

  {# ─── Summary Strip ─── #}
  <div class="summary-strip">
    <div class="summary-item">
      <div class="summary-label">Total Events</div>
      <div class="summary-value">{{ totalEvents|number_format(0, '.', ',') }}</div>
    </div>
    <div class="summary-item">
      <div class="summary-label">Most Frequent</div>
      <div class="summary-value summary-value-text">{{ topEventName ?? '&mdash;' }}</div>
      {% if topEventOccurrences is defined and topEventOccurrences %}
      <div class="summary-change summary-change-muted">{{ topEventOccurrences|number_format(0, '.', ',') }} occurrences</div>
      {% endif %}
    </div>
    <div class="summary-item">
      <div class="summary-label">Daily Actors</div>
      <div class="summary-value">{{ uniqueActors|number_format(0, '.', ',') }}</div>
    </div>
  </div>

  {# ─── Two-Pane Layout ─── #}
  <div class="event-layout">

    {# ─── List Pane ─── #}
    <div class="list-pane">
      {% if events|length > 0 %}
      {% set maxOccurrences = events|map(e => e.occurrences)|reduce((carry, v) => max(carry, v), 1) %}
      <table class="events-table"
             data-controller="row-select"
             data-row-select-url-value="{{ path('cookieless_analytics_dashboard_events_view') }}"
             data-row-select-from-value="{{ from }}"
             data-row-select-to-value="{{ to }}"
             data-row-select-frame-value="ca-event-detail">
        <thead>
          <tr>
            <th></th>
            <th>Event</th>
            <th class="num-head">Count</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {% for event in events %}
          <tr{% if selectedDetail and selectedDetail.name == event.name %} class="selected"{% endif %}
              data-action="click->row-select#select"
              data-row-select-page-url-param="{{ event.name }}">
            <td class="rank-col">{{ '%02d'|format(loop.index) }}</td>
            <td class="ev-name-col">{{ event.name }}</td>
            <td class="num-col">{{ event.occurrences|number_format(0, '.', ',') }}</td>
            <td class="bar-col"><span class="ranked-bar-track"><span class="ranked-bar-fill" style="width:{{ (event.occurrences / maxOccurrences * 100)|round }}%;"></span></span></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="ca-empty">No event data for this period</div>
      {% endif %}
    </div>

    <div class="pane-divider"></div>

    {# ─── Detail Pane ─── #}
    {% include '@CookielessAnalytics/dashboard/pages/_event_detail.html.twig' %}

  </div>
{% endblock %}
