<turbo-frame id="ca-pages-list">
<div class="list-pane">
  {% if pages|length > 0 %}
  <table class="pages-table"
         data-controller="row-select"
         data-row-select-url-value="{{ path('cookieless_analytics_dashboard_pages_view') }}"
         data-row-select-from-value="{{ from }}"
         data-row-select-to-value="{{ to }}"
         data-row-select-frame-value="ca-page-detail">
    <thead>
      <tr>
        <th></th>
        <th>Page</th>
        <th class="num-head">Views</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {% set maxViews = pages|map(p => p.views)|reduce((carry, v) => max(carry, v), 1) %}
      {% for page in pages %}
      <tr data-action="click->row-select#select"
          data-row-select-page-url-param="{{ page.pageUrl }}">
        <td class="rank-col">{{ '%02d'|format(offset + loop.index) }}</td>
        <td class="url-col">{{ page.pageUrl }}</td>
        <td class="num-col">{{ page.views|number_format(0, '.', ',') }}</td>
        <td class="bar-col"><span class="ranked-bar-track"><span class="ranked-bar-fill" style="width:{{ (page.views / maxViews * 100)|round }}%;"></span></span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="ca-empty">No pages match your search</div>
  {% endif %}
  <div class="search-hint">{{ totalDistinct }} result{{ totalDistinct != 1 ? 's' : '' }}</div>
  {% include '@CookielessAnalytics/dashboard/pages/_pagination.html.twig' %}
</div>
</turbo-frame>
