<turbo-frame id="ca-event-detail">
<div class="detail-pane">
  {% if selectedDetail %}
  <div class="detail-header">
    <div class="detail-event-name">{{ selectedDetail.name }}</div>
  </div>

  {# KPIs #}
  <div class="detail-kpis" style="grid-template-columns: 1fr 1fr;">
    <div class="detail-kpi">
      <div class="dk-label">Count</div>
      <div class="dk-value">{{ selectedDetail.occurrences|number_format(0, '.', ',') }}</div>
    </div>
    <div class="detail-kpi">
      <div class="dk-label">Distinct Values</div>
      <div class="dk-value">{{ selectedDetail.distinctValues }}</div>
    </div>
  </div>

  {# Trend Chart #}
  <div class="detail-section-label">Period Trend</div>
  <div class="detail-chart"
       data-controller="chart"
       data-chart-dates-value="{{ selectedDetail.daily|map(d => d.date)|json_encode() }}"
       data-chart-views-value="{{ selectedDetail.daily|map(d => d.count)|json_encode() }}"
       data-chart-visitors-value="[]">
  </div>

  {# Values Breakdown #}
  <div class="detail-section-label">Event Values</div>
  {% if selectedDetail.values|length > 0 %}
  {% set maxValueCount = selectedDetail.values|map(v => v.count)|reduce((carry, c) => max(carry, c), 1) %}
  <ul class="values-list">
    {% for val in selectedDetail.values %}
    <li class="value-item">
      <span class="value-name">{{ val.value }}</span>
      <div class="value-data">
        <span class="value-count">{{ val.count }}</span>
        <div class="value-bar"><div class="value-bar-fill" style="width:{{ (val.count / maxValueCount * 100)|round }}%;"></div></div>
      </div>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <div class="ca-empty" style="min-height: 60px;">No values recorded</div>
  {% endif %}

  {# Top Pages #}
  <div class="detail-section-label">Top Pages</div>
  {% if selectedDetail.pages|length > 0 %}
  <ul class="detail-pages-list">
    {% for page in selectedDetail.pages %}
    <li class="detail-page-item">
      <span class="detail-page-url">{{ page.pageUrl }}</span>
      <span class="detail-page-count">{{ page.count }}</span>
    </li>
    {% endfor %}
  </ul>
  {% else %}
  <div class="ca-empty" style="min-height: 60px;">No page data</div>
  {% endif %}

  {% else %}
  <div class="ca-empty">No event selected</div>
  {% endif %}
</div>
</turbo-frame>
